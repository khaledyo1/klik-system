rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function myUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email));
    }
    function myRole() {
      return signedIn() && myUser().exists() ? myUser().data.role : 'User';
    }
    function isSuperAdmin() {
      return signedIn() && myRole() == 'SuperAdmin';
    }
    function isManager() {
      return signedIn() && (myRole() == 'Manager' || myRole() == 'SuperAdmin');
    }
    function ownsSale() {
      return signedIn() && resource.data.addedByEmail == request.auth.token.email;
    }
    function createsOwnSale() {
      return signedIn() && request.resource.data.addedByEmail == request.auth.token.email;
    }

    match /users/{email} {
      allow read: if signedIn();
      allow create: if signedIn() && email == request.auth.token.email;
      allow update: if isSuperAdmin() || (signedIn() && email == request.auth.token.email && !('role' in request.resource.data.diff(resource.data).changedKeys()));
      allow delete: if isSuperAdmin();
    }

    match /sales/{saleId} {
      allow read: if signedIn();
      allow create: if createsOwnSale();
      allow update: if isManager() || ownsSale();
      allow delete: if isSuperAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.token.email;
      allow update: if isManager() || resource.data.createdBy == request.auth.token.email;
      allow delete: if isSuperAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isManager();
      allow create: if signedIn() && request.resource.data.actorEmail == request.auth.token.email;
      allow update, delete: if false;
    }

    match /invites/{inviteId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
